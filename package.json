{
  "name": "kraken-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev --hostname 127.0.0.1",
    "dev:turbo": "NEXT_TELEMETRY_DISABLED=1 next dev --hostname 127.0.0.1",
    "dev:debug": "NEXT_TELEMETRY_DISABLED=1 node scripts/dev-debug.mjs",
    "dev:lan": "NEXT_TELEMETRY_DISABLED=1 next dev --hostname 0.0.0.0",
    "dev:webpack": "next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .next/cache/eslint --ext .js,.jsx,.ts,.tsx",
    "lint:ci": "eslint . --max-warnings=0 --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
