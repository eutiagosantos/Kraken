# Copy to .env and fill values (see https://supabase.com/dashboard/project/_/settings/api)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- "Continuar com a Meta" (Facebook OAuth via Supabase) ---
# 1) Supabase Dashboard → Authentication → Providers → Facebook: ON + App ID + App Secret from Meta.
# 2) Meta Developer → Facebook Login → Valid OAuth Redirect URIs → add exactly:
#    ${NEXT_PUBLIC_SUPABASE_URL}/auth/v1/callback   (no trailing slash on the base URL before /auth)
# 3) Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#    http://127.0.0.1:3000  http://localhost:3000  (+ your production site URL)
#
# Optional: local Supabase (supabase start) — set enabled = true under [auth.external.facebook] in
# supabase/config.toml and define:
# SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=
# Then add http://127.0.0.1:54321/auth/v1/callback to Meta Valid OAuth Redirect URIs.
